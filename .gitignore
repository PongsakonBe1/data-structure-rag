# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
env/
ENV/
.venv/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Environment variables
.env
.env.local
.env.*.local

# Large data files (don't upload to GitHub)
data/*.pdf
data/*.zip
data/*.tar.gz

# Model weights (large files)
*.bin
*.pt
*.pth
*.ckpt
*.safetensors

# Allow index files (small, needed for RAG)
# These are required for the app to work on Streamlit Cloud
!indexes/
!indexes/**/*.json
!indexes/**/*.jsonl
!indexes/**/*.pkl
!indexes/**/*.faiss
!indexes/**/*.index
!indexes/**/index.*

# Logs (too large)
logs/__debug_*
logs/__diag_*
logs/__smoke_*
logs/_cmp_*
logs/_debug_*
logs/_smoke_*
logs/_tmp_*
logs/visual_*
logs/*.jsonl
logs/*.log

# Temporary files
*.tmp
*.temp
*.bak
*.backup

# OS files
.DS_Store
Thumbs.db

# Streamlit secrets
.secrets.toml
